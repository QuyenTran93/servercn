{
  "name": "@quyentran93/servercn-cli",
  "version": "1.1.10",
  "description": "Backend components CLI for Node.js & Typescript",
  "main": "dist/cli.js",
  "readme": "README.md",
  "bin": {
    "servercn": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:merge-marker": "tsx src/lib/merge-marker.selftest.ts",
    "test:express-merge-foundation": "tsx src/lib/express-merge-foundation.selftest.ts",
    "test:express-merge-slugs": "tsx src/constants/express-merge-slugs.selftest.ts",
    "test:express-component-deps": "tsx src/constants/express-component-dependency-rules.selftest.ts",
    "test:express-merge-all": "npm run test:merge-marker && npm run test:express-merge-foundation && npm run test:express-merge-slugs && npm run test:express-component-deps",
    "prepublishOnly": "npm run build",
    "pub": "npm publish"
  },
  "keywords": [
    "servercn",
    "cli",
    "backend",
    "typescript",
    "node.js",
    "express",
    "nodejs",
    "scaffold",
    "boilerplate",
    "component"
  ],
  "author": {
    "name": "Akkal Dhami",
    "github": "https://github.com/QuyenTran93",
    "url": "https://x.com/AavashDhami2127"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QuyenTran93/servercn.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "dependencies": {
    "cli-table3": "^0.6.5",
    "commander": "^14.0.2",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.3",
    "glob": "^10.5.0",
    "kleur": "^3.0.3",
    "ora": "^9.3.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.0.3",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
