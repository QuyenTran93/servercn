{
  "$schema": "https://servercn.vercel.app/schema/foundation.registry.json",
  "slug": "mongoose-starter",
  "runtimes": {
    "node": {
      "frameworks": {
        "express": {
          "templates": {
            "mvc": "mongoose-starter/mvc",
            "feature": "mongoose-starter/feature"
          },
          "dependencies": {
            "runtime": [
              "express",
              "cors",
              "dotenv-flow",
              "cross-env",
              "helmet",
              "cookie-parser",
              "mongoose",
              "pino-pretty",
              "pino",
              "source-map-support",
              "zod",
              "swagger-autogen",
              "swagger-ui-express"
            ],
            "dev": [
              "typescript",
              "tsx",
              "tsc-alias",
              "@types/node",
              "@types/express",
              "morgan",
              "@types/cors",
              "@types/morgan",
              "@types/cookie-parser",
              "prettier",
              "@commitlint/cli",
              "@commitlint/config-conventional",
              "@types/source-map-support",
              "lint-staged",
              "@typescript-eslint/eslint-plugin",
              "@typescript-eslint/parser",
              "eslint",
              "eslint-plugin-prettier",
              "@types/swagger-ui-express"
            ]
          },
          "env": [
            "LOG_LEVEL",
            "NODE_ENV",
            "PORT",
            "CORS_ORIGIN",
            "DATABASE_URL"
          ]
        }
      }
    }
  }
}
