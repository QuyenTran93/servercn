{
  "slug": "prettier",
  "templates": {
    "base": {
      "files": [
        {
          "type": "tooling",
          "path": ".prettierrc",
          "content": "{\n  \"singleQuote\": false,\n  \"semi\": true,\n  \"tabWidth\": 2,\n  \"trailingComma\": \"none\",\n  \"bracketSameLine\": true,\n  \"arrowParens\": \"avoid\",\n  \"endOfLine\": \"lf\"\n}\n"
        },
        {
          "type": "tooling",
          "path": ".prettierignore",
          "content": "dist\nnode_modules\ncoverage\n.env\n.env.*\n!.env.example\n"
        }
      ]
    }
  },
  "dependencies": {
    "runtime": [],
    "dev": [
      "prettier"
    ]
  }
}
